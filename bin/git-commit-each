#!/bin/bash
# Commit all modified files in commits with one modified file per commit
set -e

"$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/refuse-coding-agent" "${0##*/}"

FILES="$(mktemp)"
trap 'rm -f "$FILES"' EXIT

git ls-files -z --modified --others --exclude-standard >"$FILES"
[ -s "$FILES" ] || exit 0

git add --pathspec-from-file="$FILES" --pathspec-file-nul

while IFS= read -r -d '' FILENAME <&3; do
  MESSAGE="$(echo "$FILENAME" | sed -e 's|^Library/Homebrew/||' \
    -e 's|^Formula/||' \
    -e 's|^Casks/||' \
    -e 's|^[0-9a-z]/||' \
    -e 's|^font/\(font-[0-9a-z]/\)\{0,1\}||' \
    -e 's|^lib/||' \
    -e 's/\.rb//' \
    -e 's/$/: /')"
  git -c core.hooksPath=/dev/null commit "$FILENAME" --message="${MESSAGE}${1}" --message="${2}"
done 3<"$FILES"
