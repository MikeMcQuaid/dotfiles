#!/bin/bash
# Update all Git and Subversion repositories under the current directory.
set -e

CURRENT=$PWD
# `find -print0` with `IFS= read -r -d ''` keeps spaced paths safe here.

echorun() {
  echo + "$@"
  "$@"
}

find -L "$CURRENT" \( -name .git -or -name .svn \) -print0 | while IFS= read -r -d '' SCM; do
  DIRECTORY="${SCM%/*}"
  cd "$DIRECTORY" || continue
  if [ -d ../.svn ] || [[ "${DIRECTORY}" == *vendor/ruby* ]]; then
    continue
  fi
  echo "== Updating ${DIRECTORY##*/}"
  if [ -d .git/svn ]; then
    echorun git svn fetch
    echorun git svn rebase
  elif [ -d .git ]; then
    echorun git fetch --all
    if [ -n "$(git remote -v)" ]; then
      echorun git checkout --quiet master || echorun git checkout --quiet main || echorun git checkout --quiet trunk
      echorun git merge --no-edit --ff-only origin/HEAD
      git branch --merged | grep -v '\*' | xargs -n 1 git branch -d
    fi
  elif [ -d .svn ]; then
    echorun svn update
  fi
  echo
done
