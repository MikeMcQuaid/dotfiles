#!/bin/bash
# Garbage collect all Git repositories under the current directory.
set -e

CURRENT=$PWD
# `find -print0` with `IFS= read -r -d ''` keeps spaced paths safe here.

echorun() {
  echo + "$@"
  "$@"
}

find -L "$CURRENT" -name .git -print0 | while IFS= read -r -d '' SCM; do
  DIRECTORY="${SCM%/*}"
  cd "$DIRECTORY" || continue
  echo "== Garbage collecting ${DIRECTORY##*/}"
  if [ -d .git ]; then
    echorun git gc --aggressive
  fi
  echo
done
