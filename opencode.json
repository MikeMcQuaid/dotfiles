{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen3-coder-30b-64k",
  "small_model": "ollama/qwen3-coder-30b-64k",
  "default_agent": "build",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder-30b-64k": {
          "name": "Qwen3 Coder (fast)",
          "limit": {
            "context": 65536,
            "output": 16384
          }
        },
        "qwen3-coder-next-32k": {
          "name": "Qwen3 Coder (smart)",
          "limit": {
            "context": 32768,
            "output": 16384
          }
        }
      }
    }
  },
  "agent": {
    "build": {
      "model": "ollama/qwen3-coder-30b-64k",
      "temperature": 0.1
    },
    "plan": {
      "model": "ollama/qwen3-coder-next-32k",
      "temperature": 0.1
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      "coverage/**",
      "target/**",
      ".next/**"
    ]
  }
}
