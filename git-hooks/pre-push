#!/bin/bash
set -euo pipefail

if [[ "$(uname -s)" = "Linux" ]] &&
   ! grep -qEi "(Microsoft|WSL)" /proc/version &&
   [[ "$(git config --get gpg.format 2>/dev/null || true)" = "ssh" ]] &&
   ! git config --get user.signingkey &>/dev/null &&
   ! git config --get gpg.ssh.defaultKeyCommand &>/dev/null; then
  echo "Warning: Git SSH signing is not set up; skipping push signature checks." >&2
  exit 0
fi

# If git did not pipe a ref list on stdin (e.g. stdin is a terminal under a
# sandboxed git wrapper), there is nothing to verify; exit rather than block
# forever on `read`.
if [ -t 0 ]; then
  exit 0
fi

# Reject pushes that include unsigned or invalidly signed commits.
# Skip deletions and refs that do not peel to a commit.
while read -r local_ref local_oid _ _; do
  status="$(git log -1 '--format=%G?' "${local_oid}^{commit}" 2>/dev/null)" || continue

  case "${status}" in
    G|U|X|Y)
      ;;
    N)
      echo "Push rejected: ${local_ref} is not signed" >&2
      exit 1
      ;;
    *)
      echo "Push rejected: ${local_ref} signature is not valid" >&2
      exit 1
      ;;
  esac
done
